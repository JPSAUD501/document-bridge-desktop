{
  "name": "pegasus-desktop",
  "private": true,
  "version": "1.0.35",
  "description": "Pegasus — Desktop automation for ERP-to-MIDAS document workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/JPSAUD501/document-bridge-desktop.git"
  },
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node scripts/clean-build.mjs",
    "dev": "concurrently -k -n MAIN,PRELOAD,RENDERER,ELECTRON -c blue,magenta,green,yellow \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsx watch scripts/build-electron-main.ts --watch",
    "dev:preload": "tsx watch scripts/build-electron-preload.ts --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 dist-electron/main/index.cjs dist-electron/preload/index.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:main": "tsx scripts/build-electron-main.ts",
    "build:preload": "tsx scripts/build-electron-preload.ts",
    "build": "npm run clean && npm run typecheck && npm run build:main && npm run build:preload && vite build",
    "package": "npm run build && electron-builder --win nsis",
    "release:github": "npm run build && electron-builder --publish always --win nsis",
    "version:next": "tsx scripts/next-version.ts",
    "gen:icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "com.pegasus.desktop",
    "productName": "Pegasus",
    "icon": "resources/icon.png",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/tray.png",
        "to": "tray.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JPSAUD501",
        "repo": "document-bridge-desktop"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "win": {
      "signAndEditExecutable": false,
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    }
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.0.1",
    "motion": "^12.38.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.9",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
